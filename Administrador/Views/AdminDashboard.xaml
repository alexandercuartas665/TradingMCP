<Window x:Class="Administrador.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obsidian Admin — Trading Systems"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="960"
        Background="#131313"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════
             COLOR TOKENS  (DESIGN.md  "Obsidian Lens")
        ═══════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase"           Color="#131313"/>
        <SolidColorBrush x:Key="SurfaceLow"       Color="#1C1B1B"/>
        <SolidColorBrush x:Key="SurfaceHigh"      Color="#2A2A2A"/>
        <SolidColorBrush x:Key="SurfaceLowest"    Color="#0E0E0E"/>
        <SolidColorBrush x:Key="SurfaceVariant"   Color="#353534"/>
        <SolidColorBrush x:Key="Primary"          Color="#D0F2FF"/>
        <SolidColorBrush x:Key="PrimaryFixed"     Color="#4CD6FB"/>
        <SolidColorBrush x:Key="PrimaryContainer" Color="#72DEFF"/>
        <SolidColorBrush x:Key="OnSurface"        Color="#E5E2E1"/>
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#BAC9CC"/>
        <SolidColorBrush x:Key="Error"            Color="#FFB4AB"/>
        <SolidColorBrush x:Key="OutlineVariant"   Color="#3B494C"/>
        <SolidColorBrush x:Key="SidebarBg"        Color="#0A0A0A"/>

        <!-- Gradiente primario para botones CTA -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D0F2FF" Offset="0"/>
            <GradientStop Color="#72DEFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ESTILOS GLOBALES -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariant}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="CyanValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryFixed}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#7A8A8D"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2A2A"/>
                                <Setter Property="Foreground" Value="#BAC9CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
            <Setter Property="Background" Value="#0D2A30"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryFixed}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4CD6FB" Opacity="0.6"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>0,0,0,0</Border.BorderThickness>
                            <Grid>
                                <Border Width="3" HorizontalAlignment="Left" CornerRadius="3"
                                        Background="{StaticResource PrimaryFixed}" Margin="-14,0,0,0"/>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceLow}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,18"/>
        </Style>

        <Style x:Key="AgentCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceLow}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="LogEntry" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#7A8A8D"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="#0A1E27"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurface}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="Fill" Value="{StaticResource PrimaryFixed}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TagBadge" TargetType="Border">
            <Setter Property="Background" Value="#0D2A30"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════
         LAYOUT ROOT: Sidebar | Main
    ═══════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════ SIDEBAR ════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="6" Background="{StaticResource PrimaryFixed}"
                                VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="⬡" FontSize="14" Foreground="#001F27"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Obsidian Admin" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource Primary}"/>
                            <TextBlock Text="TRADING SYSTEMS" FontSize="9" FontWeight="SemiBold"
                                       Foreground="#3B4A4D"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- New Strategy CTA -->
                <Border DockPanel.Dock="Top" Margin="14,0,14,20">
                    <Button Style="{StaticResource PrimaryBtn}" Content="+ Nueva Estrategia"
                            HorizontalAlignment="Stretch"/>
                </Border>

                <!-- Nav Items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0,8,0">
                    <!-- Active -->
                    <Button x:Name="btnNavDashboard" Style="{StaticResource NavItemActive}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬛" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource PrimaryFixed}"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"
                                       Foreground="{StaticResource PrimaryFixed}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavUsers" Style="{StaticResource NavItem}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Usuarios" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavAccounts" Style="{StaticResource NavItem}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💼" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Cuentas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavPlatforms" Style="{StaticResource NavItem}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Plataformas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavMonitoring" Style="{StaticResource NavItem}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Monitoreo" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnNavSettings" Style="{StaticResource NavItem}"
                            HorizontalAlignment="Stretch" Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer usuario -->
                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,20">
                    <Button Style="{StaticResource NavItem}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Cerrar Sesión" FontSize="12" Foreground="#5A6A6D"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="#1C1B1B" Margin="4,6"/>
                    <StackPanel Orientation="Horizontal" Margin="4,8,0,0">
                        <Border Width="32" Height="32" CornerRadius="16"
                                Background="{StaticResource SurfaceHigh}" Margin="0,0,10,0">
                            <TextBlock Text="AS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryFixed}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Alex Sterling" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource OnSurface}"/>
                            <TextBlock Text="Lead System Admin" FontSize="10" Foreground="#3B4A4D"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Grid/><!-- spacer -->
            </DockPanel>
        </Border>

        <!-- ════════════════════ MAIN AREA ════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="#0A0A0A">
                <Grid Margin="24,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="Obsidian Lens" FontSize="16" FontWeight="Black"
                                   Foreground="{StaticResource OnSurface}" VerticalAlignment="Center"/>
                        <TextBlock Text=" / " FontSize="14" Foreground="#3B4A4D"
                                   VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Text="Network Status" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryFixed}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock x:Name="txtClock" Text="--:--:-- UTC" FontFamily="Consolas"
                                   FontSize="11" Foreground="#3B4A4D" VerticalAlignment="Center"
                                   Margin="0,0,20,0"/>
                        <Ellipse Fill="{StaticResource PrimaryFixed}" Width="8" Height="8"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Secure Link" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource OnSurfaceVariant}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- DASHBOARD CANVAS -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BgBase}">
                <StackPanel Margin="28,24,28,40">

                    <!-- ── HEADER ── -->
                    <Grid Margin="0,0,0,28">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="PORTFOLIO ANALYSIS" Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="System Overview" FontSize="36" FontWeight="Black"
                                       Foreground="{StaticResource OnSurface}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="LAST UPDATED" Style="{StaticResource LabelStyle}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="txtLastUpdated" Text="--:--:-- UTC"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariant}"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── METRICS GRID (4 tarjetas) ── -->
                    <UniformGrid Columns="4" Margin="0,0,0,28">
                        <!-- Total Equity -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4CD6FB" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>0,0,0,3</Border.BorderThickness>
                            <StackPanel>
                                <TextBlock Text="TOTAL EQUITY" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="$1,429,203" Style="{StaticResource ValueStyle}"/>
                                    <TextBlock Text=" +2.4%" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryFixed}"
                                               VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                                </StackPanel>
                                <Border Height="3" Margin="0,12,0,0" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4CD6FB" Offset="0"/>
                                            <GradientStop Color="#4CD6FB" Offset="0.75"/>
                                            <GradientStop Color="#1C1B1B" Offset="0.75"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Daily P&L -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="DAILY P&amp;L" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="+$12,403.82" Style="{StaticResource CyanValue}"/>
                                <TextBlock Text="14 trades cerrados hoy" Style="{StaticResource LabelStyle}"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Agentes activos -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="AGENTES ACTIVOS" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="12" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="Todos los sistemas operativos"
                                           Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Connection Status -->
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="CONEXIONES" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Postgres Cluster"
                                               Foreground="{StaticResource OnSurfaceVariant}" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Ellipse Style="{StaticResource StatusDot}" Margin="0,0,5,0"/>
                                        <TextBlock Text="Healthy" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryFixed}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Deriv API"
                                               Foreground="{StaticResource OnSurfaceVariant}" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Ellipse Style="{StaticResource StatusDot}" Margin="0,0,5,0"/>
                                        <TextBlock Text="12 ms" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryFixed}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- ── SECTION: AGENTES + LOG ── -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Agentes -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="Active Agent Status"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurface}"/>
                                <TextBlock Text="Ver todos los clusters" HorizontalAlignment="Right"
                                           FontSize="11" Foreground="{StaticResource PrimaryFixed}"
                                           VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <UniformGrid Columns="3">
                                <!-- Agent 1 -->
                                <Border Style="{StaticResource AgentCard}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="📈" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="POLLING" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="MarketDataAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Aggregating L2 order book data BTC/USD"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:01] Received snapshot"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:03] Websocket synced"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Agent 2 -->
                                <Border Style="{StaticResource AgentCard}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="🧠" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="COMPUTING" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="DecisionAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Analizando RSI y MACD 5m timeframe"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:21:55] Pattern detected"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="#5A6A6D"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:05] Awaiting confirmation"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Agent 3 -->
                                <Border Style="{StaticResource AgentCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="🛡" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="ACTIVE" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="RiskAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Monitoreando exposición y drawdowns"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:19:00] Exposure: 1.2%"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:08] Limits verified"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <!-- System Log -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="System Logs" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurface}" Margin="0,0,0,14"/>
                            <Border Background="{StaticResource SurfaceLowest}" CornerRadius="10"
                                    Height="210">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Padding="14,10" Background="#0D0D0D"
                                            CornerRadius="10,10,0,0">
                                        <Grid>
                                            <TextBlock Text="LIVE STREAM" FontSize="9" FontWeight="Bold"
                                                       Foreground="#3B494C"/>
                                            <Ellipse Fill="{StaticResource Error}" Width="8" Height="8"
                                                     HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#080808">
                                        <Grid>
                                            <TextBox x:Name="txtLogFilter"
                                                     Background="#0E0E0E" BorderThickness="0"
                                                     Foreground="{StaticResource OnSurfaceVariant}"
                                                     FontFamily="Consolas" FontSize="10"
                                                     Padding="6,4" VerticalContentAlignment="Center"
                                                     Text="Filtrar logs..."/>
                                            <Button HorizontalAlignment="Right"
                                                    Style="{StaticResource GhostBtn}"
                                                    Padding="8,4" Content="EXPORT" FontSize="9"/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer x:Name="svLog" VerticalScrollBarVisibility="Auto"
                                                  Padding="12,8">
                                        <StackPanel x:Name="pnlLog">
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:15</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Order execution successful: BUY 0.5 BTC</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:12</Run>
                                                <Run Foreground="#5A6A6D"> [DEBUG] Heartbeat Frankfurt node_04</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource Error}">14:22:10</Run>
                                                <Run Foreground="#5A6A6D"> [WARN] High latency Deriv API (145ms)</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:08</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] RiskAgent cleared margin requirements</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:21:58</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Strategy Obsidian_V4 initialized</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:21:42</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Batch update: 12,049 records OK</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ── MARKET SENTIMENT BANNER ── -->
                    <Border CornerRadius="12" Padding="28,22" Margin="0,0,0,8">
                        <Border.Background>
                            <SolidColorBrush Color="#1C1B1B"/>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Glow decoration -->
                            <Ellipse Width="200" Height="200" HorizontalAlignment="Right"
                                     VerticalAlignment="Top" Margin="0,-80,-80,0" Opacity="0.04">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#4CD6FB" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Market Sentiment Analysis" FontSize="20"
                                           FontWeight="Bold" Foreground="{StaticResource OnSurface}"
                                           Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource OnSurfaceVariant}"
                                           TextWrapping="Wrap" MaxWidth="500">
                                    <Run>Inferencia IA combinada (social, noticias, on-chain) indica divergencia</Run>
                                    <Run Foreground="{StaticResource PrimaryFixed}" FontWeight="Bold"> Strong Bullish</Run>
                                    <Run> en la próxima ventana de 4h.</Run>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="40,0">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="VOL INDEX" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="24.5" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurface}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="BUY/SELL" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="1.42" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurface}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="CONFIDENCE" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="88%" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryFixed}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                    Content="Open Analytics Engine" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── STATUS BAR ── -->
                    <Border Padding="0,10,0,0" Margin="0,8,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="NODE: FRA-1" FontFamily="Consolas" FontSize="9"
                                           Foreground="#3B4A4D" Margin="0,0,20,0"/>
                                <TextBlock Text="VERSION: 1.0.0-ALPHA" FontFamily="Consolas"
                                           FontSize="9" Foreground="#3B4A4D"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Fill="{StaticResource PrimaryFixed}" Width="7" Height="7"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="SECURE LINK ESTABLISHED" FontFamily="Consolas"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
