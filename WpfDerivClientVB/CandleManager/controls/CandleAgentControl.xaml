<UserControl x:Class="CandleAgentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300" Background="#0A0A0A">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#3B4A4D"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="IndicatorRow" TargetType="Border">
            <Setter Property="Background" Value="#1C1B1B"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="LogRow" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="#1C1B1B" BorderThickness="1,0,0,0">
        <DockPanel Background="#0A0A0A">

            <!-- ── AGENT HEADER ── -->
            <Border DockPanel.Dock="Top" Padding="18,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D0D0D" Offset="0"/>
                        <GradientStop Color="#0D2A30" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🤖" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="AGENTE IA PRO" FontSize="10" FontWeight="Black"
                                           FontFamily="Consolas" Foreground="#e0e6ed"/>
                                <TextBlock Text="MARKET ANALYSIS ENGINE" FontSize="8"
                                           FontFamily="Consolas" Foreground="#3B4A4D"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse x:Name="ellAgentStatus" Width="7" Height="7" Fill="#00d4aa"
                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="txtAgentStatus" Text="ANALIZANDO"
                                       FontSize="8" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#00d4aa" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Decision card -->
                    <Border x:Name="bdrDecision" CornerRadius="10" Padding="16,14">
                        <Border.Background>
                            <SolidColorBrush x:Name="decisionBg" Color="#1C2E2B"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="decisionBorder" Color="#00d4aa"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>2</Border.BorderThickness>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DECISIÓN DEL AGENTE" FontSize="8" FontWeight="Bold"
                                       FontFamily="Consolas" Foreground="#5A6A6D"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtDecision" Text="NEUTRO"
                                       FontSize="28" FontWeight="Black"
                                       HorizontalAlignment="Center" Margin="0,0,0,6">
                                <TextBlock.Foreground>
                                    <SolidColorBrush x:Name="decisionFg" Color="#5A6A6D"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#5A6A6D"
                                       HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Run Text="Confianza: "/>
                                <Run x:Name="runConfidence" Text="—%" FontWeight="Bold"
                                     Foreground="#4CD6FB"/>
                            </TextBlock>
                            <!-- Confidence bar -->
                            <Border Height="5" CornerRadius="3" Background="#1C1B1B">
                                <Border x:Name="bdrConfidenceBar" HorizontalAlignment="Left"
                                        Height="5" CornerRadius="3" Width="0">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="confBarColor" Color="#5A6A6D"/>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── INDICATORS ── -->
            <Border DockPanel.Dock="Top" Padding="18,14" BorderBrush="#1C1B1B" BorderThickness="0,1,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="INDICADORES TÉCNICOS" Style="{StaticResource SectionLabel}" Margin="0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="5" Height="5" Fill="#00d4aa" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="LIVE" FontSize="8" FontWeight="Bold"
                                       FontFamily="Consolas" Foreground="#00d4aa"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource IndicatorRow}">
                        <Grid>
                            <TextBlock Text="RSI (14)" Foreground="#5A6A6D" FontSize="11"/>
                            <TextBlock x:Name="txtRsi" Text="—" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#e0e6ed"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource IndicatorRow}">
                        <Grid>
                            <TextBlock Text="MACD" Foreground="#5A6A6D" FontSize="11"/>
                            <TextBlock x:Name="txtMacd" Text="—" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#e0e6ed"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource IndicatorRow}">
                        <Grid>
                            <TextBlock Text="SMA 20/50" Foreground="#5A6A6D" FontSize="11"/>
                            <TextBlock x:Name="txtSma" Text="—" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#e0e6ed"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource IndicatorRow}">
                        <Grid>
                            <TextBlock Text="Volumen" Foreground="#5A6A6D" FontSize="11"/>
                            <TextBlock x:Name="txtVol" Text="—" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#e0e6ed"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── SIGNAL LOG ── -->
            <Border DockPanel.Dock="Top" Padding="18,14,18,0" BorderBrush="#1C1B1B" BorderThickness="0,1,0,0">
                <StackPanel>
                    <TextBlock Text="HISTORIAL DE SEÑALES" Style="{StaticResource SectionLabel}"/>
                    <ScrollViewer x:Name="svLog" VerticalScrollBarVisibility="Hidden" MaxHeight="140">
                        <StackPanel x:Name="pnlLog"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Filler -->
            <Border Background="#0A0A0A"/>
        </DockPanel>
    </Border>
</UserControl>
