<UserControl x:Class="CandleTransactionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="120" Background="#0A0A0A">

    <Border BorderBrush="#1C1B1B" BorderThickness="0,1,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Section label -->
            <Border Grid.Column="0" Background="#0D0D0D" Padding="16,0" BorderBrush="#1C1B1B" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TRANSACCIONES" FontSize="9" FontWeight="Black"
                               FontFamily="Consolas" Foreground="#3B4A4D"/>
                    <TextBlock x:Name="txtTxCount" Text="0 ops hoy"
                               FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="#5A6A6D" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border Background="#0D2A30" CornerRadius="4" Padding="6,3" Margin="0,0,6,0">
                            <TextBlock x:Name="txtPnl" Text="P&amp;L: —"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#4CD6FB"/>
                        </Border>
                        <Border Background="#1C1B1B" CornerRadius="4" Padding="6,3">
                            <TextBlock x:Name="txtWinRate" Text="WR: —"
                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="#5A6A6D"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Transaction list -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel x:Name="pnlTransactions" Margin="4,6"/>
            </ScrollViewer>

            <!-- Stats panel -->
            <Border Grid.Column="2" Background="#0D0D0D" Padding="16,0"
                    BorderBrush="#1C1B1B" BorderThickness="1,0,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="RESUMEN" FontSize="8" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="#3B4A4D" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="GANADAS"
                                   FontSize="9" FontFamily="Consolas" Foreground="#5A6A6D"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtWins" Text="0"
                                   FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="#00d4aa" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="PERDIDAS"
                                   FontSize="9" FontFamily="Consolas" Foreground="#5A6A6D"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtLosses" Text="0"
                                   FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="#ff4757" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="TOTAL"
                                   FontSize="9" FontFamily="Consolas" Foreground="#5A6A6D"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtTotal" Text="0"
                                   FontSize="9" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="#e0e6ed" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
