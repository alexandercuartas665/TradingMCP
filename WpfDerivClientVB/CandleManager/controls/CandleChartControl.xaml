<UserControl x:Class="CandleChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#131722" ClipToBounds="True">

    <Grid>
        <!-- Main chart canvas -->
        <Canvas x:Name="chartCanvas" Background="#131722"
                MouseMove="ChartCanvas_MouseMove"
                MouseLeave="ChartCanvas_MouseLeave"/>

        <!-- Crosshair overlay (drawn programmatically) -->
        <Canvas x:Name="crosshairCanvas" IsHitTestVisible="False"/>

        <!-- OHLC Tooltip on hover -->
        <Border x:Name="tooltipPanel" Background="#0D2A30"
                BorderBrush="#4CD6FB" BorderThickness="1"
                CornerRadius="6" Padding="12,8"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="12,10,0,0" Opacity="0"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock x:Name="txtTooltipTime" Text="--:--"
                           FontFamily="Consolas" FontSize="9"
                           Foreground="#5A6A6D" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Open"  Foreground="#5A6A6D" FontSize="10"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTipOpen"  Text="—" Foreground="#e0e6ed" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="High"  Foreground="#5A6A6D" FontSize="10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtTipHigh"  Text="—" Foreground="#00d4aa" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Low"   Foreground="#5A6A6D" FontSize="10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtTipLow"   Text="—" Foreground="#ff4757" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Close" Foreground="#5A6A6D" FontSize="10"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtTipClose" Text="—" Foreground="#4CD6FB" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Vol"   Foreground="#5A6A6D" FontSize="10"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtTipVol"   Text="—" Foreground="#e0e6ed" FontSize="10" FontFamily="Consolas"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Legend top-right -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,10,0" Orientation="Horizontal">
            <Border Background="#0A0A0A" CornerRadius="4" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="20" Height="2" Fill="#2962FF" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="SMA 20" FontSize="9" FontFamily="Consolas" Foreground="#5A6A6D"/>
                    <Rectangle Width="20" Height="2" Fill="#FF6D00" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <TextBlock Text="SMA 50" FontSize="9" FontFamily="Consolas" Foreground="#5A6A6D"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- No data overlay -->
        <Border x:Name="noDataPanel" Background="#131722" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Sin datos — selecciona un activo"
                           FontSize="14" FontFamily="Consolas"
                           Foreground="#3B4A4D" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
