<Window x:Class="DbConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pro Trading AI — Configuración de Base de Datos"
        Height="620" Width="660"
        MinHeight="500" MinWidth="540"
        Background="#0A0A0A"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- El control de configuración ocupa toda la ventana -->
        <ContentControl x:Name="ConfigContainer"/>
    </Grid>
</Window>
