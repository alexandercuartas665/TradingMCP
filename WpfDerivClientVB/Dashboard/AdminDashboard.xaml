<Window x:Class="AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obsidian Admin — Trading Systems"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="960"
        Background="#131313"
        WindowStartupLocation="CenterScreen">

    

    <!-- ═══════════════════════════════════════════════
         LAYOUT ROOT: Sidebar | Main
    ═══════════════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl x:Name="SidebarContainer" Margin="0,0,0,0" />

        <!-- ════════════════════ MAIN AREA ════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="#0A0A0A">
                <Grid Margin="24,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="Obsidian Lens" FontSize="16" FontWeight="Black"
                                   Foreground="{StaticResource OnSurface}" VerticalAlignment="Center"/>
                        <TextBlock Text=" / " FontSize="14" Foreground="#3B4A4D"
                                   VerticalAlignment="Center" Margin="8,0"/>
                        <TextBlock Text="Network Status" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryFixed}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock x:Name="txtClock" Text="--:--:-- UTC" FontFamily="Consolas"
                                   FontSize="11" Foreground="#3B4A4D" VerticalAlignment="Center"
                                   Margin="0,0,20,0"/>
                        <Ellipse Fill="{StaticResource PrimaryFixed}" Width="8" Height="8"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- DASHBOARD CANVAS (Static) -->
            <ScrollViewer x:Name="DashboardCanvas" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BgBase}">
                <StackPanel Margin="28,24,28,40">

                    <!-- ── HEADER ── -->
                    <Grid Margin="0,0,0,28">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="PORTFOLIO ANALYSIS" Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="System Overview" FontSize="36" FontWeight="Black"
                                       Foreground="{StaticResource OnSurface}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <TextBlock Text="LAST UPDATED" Style="{StaticResource LabelStyle}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="txtLastUpdated" Text="--:--:-- UTC"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource OnSurfaceVariant}"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── METRICS GRID (4 tarjetas) ── -->
                    <UniformGrid Columns="4" Margin="0,0,0,28">
                        <!-- Total Equity -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4CD6FB" Opacity="0.3"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>0,0,0,3</Border.BorderThickness>
                            <StackPanel>
                                <TextBlock Text="TOTAL EQUITY" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="$1,429,203" Style="{StaticResource ValueStyle}"/>
                                    <TextBlock Text=" +2.4%" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryFixed}"
                                               VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                                </StackPanel>
                                <Border Height="3" Margin="0,12,0,0" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4CD6FB" Offset="0"/>
                                            <GradientStop Color="#4CD6FB" Offset="0.75"/>
                                            <GradientStop Color="#1C1B1B" Offset="0.75"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Daily P&L -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="DAILY P&amp;L" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="+$12,403.82" Style="{StaticResource CyanValue}"/>
                                <TextBlock Text="14 trades cerrados hoy" Style="{StaticResource LabelStyle}"
                                           Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Agentes activos -->
                        <Border Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="AGENTES ACTIVOS" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="12" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Text="Todos los sistemas operativos"
                                           Style="{StaticResource LabelStyle}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Connection Status -->
                        <Border Style="{StaticResource MetricCard}">
                            <StackPanel>
                                <TextBlock Text="CONEXIONES" Style="{StaticResource LabelStyle}"
                                           Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Postgres Cluster"
                                               Foreground="{StaticResource OnSurfaceVariant}" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Ellipse Style="{StaticResource StatusDot}" Margin="0,0,5,0"/>
                                        <TextBlock Text="Healthy" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryFixed}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Deriv API"
                                               Foreground="{StaticResource OnSurfaceVariant}" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Ellipse Style="{StaticResource StatusDot}" Margin="0,0,5,0"/>
                                        <TextBlock Text="12 ms" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryFixed}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- ── SECTION: AGENTES + LOG ── -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Agentes -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,14">
                                <TextBlock Text="Active Agent Status"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurface}"/>
                                <TextBlock Text="Ver todos los clusters" HorizontalAlignment="Right"
                                           FontSize="11" Foreground="{StaticResource PrimaryFixed}"
                                           VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <UniformGrid Columns="3">
                                <!-- Agent 1 -->
                                <Border Style="{StaticResource AgentCard}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="📈" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="POLLING" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="MarketDataAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Aggregating L2 order book data BTC/USD"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:01] Received snapshot"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:03] Websocket synced"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Agent 2 -->
                                <Border Style="{StaticResource AgentCard}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="🧠" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="COMPUTING" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="DecisionAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Analizando RSI y MACD 5m timeframe"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:21:55] Pattern detected"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="#5A6A6D"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:05] Awaiting confirmation"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Agent 3 -->
                                <Border Style="{StaticResource AgentCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Border Width="32" Height="32" CornerRadius="8"
                                                    Background="#0D2A30" HorizontalAlignment="Left">
                                                <TextBlock Text="🛡" FontSize="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Style="{StaticResource TagBadge}"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="ACTIVE" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryFixed}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="RiskAgent" FontWeight="Bold"
                                                   FontSize="13" Foreground="{StaticResource OnSurface}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Monitoreando exposición y drawdowns"
                                                   FontSize="10" Foreground="#5A6A6D"
                                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:19:00] Exposure: 1.2%"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#070F0F" CornerRadius="4" Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource PrimaryFixed}"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="[14:22:08] Limits verified"
                                                           Style="{StaticResource LogEntry}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <!-- System Log -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="System Logs" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource OnSurface}" Margin="0,0,0,14"/>
                            <Border Background="{StaticResource SurfaceLowest}" CornerRadius="10"
                                    Height="210">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Padding="14,10" Background="#0D0D0D"
                                            CornerRadius="10,10,0,0">
                                        <Grid>
                                            <TextBlock Text="LIVE STREAM" FontSize="9" FontWeight="Bold"
                                                       Foreground="#3B494C"/>
                                            <Ellipse Fill="{StaticResource Error}" Width="8" Height="8"
                                                     HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#080808">
                                        <Grid>
                                            <TextBox x:Name="txtLogFilter"
                                                     Background="#0E0E0E" BorderThickness="0"
                                                     Foreground="{StaticResource OnSurfaceVariant}"
                                                     FontFamily="Consolas" FontSize="10"
                                                     Padding="6,4" VerticalContentAlignment="Center"
                                                     Text="Filtrar logs..."/>
                                            <Button HorizontalAlignment="Right"
                                                    Style="{StaticResource GhostBtn}"
                                                    Padding="8,4" Content="EXPORT" FontSize="9"/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer x:Name="svLog" VerticalScrollBarVisibility="Auto"
                                                  Padding="12,8">
                                        <StackPanel x:Name="pnlLog">
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:15</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Order execution successful: BUY 0.5 BTC</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:12</Run>
                                                <Run Foreground="#5A6A6D"> [DEBUG] Heartbeat Frankfurt node_04</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource Error}">14:22:10</Run>
                                                <Run Foreground="#5A6A6D"> [WARN] High latency Deriv API (145ms)</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:22:08</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] RiskAgent cleared margin requirements</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:21:58</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Strategy Obsidian_V4 initialized</Run>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource LogEntry}" Margin="0,0,0,6">
                                                <Run Foreground="{StaticResource PrimaryFixed}">14:21:42</Run>
                                                <Run Foreground="#5A6A6D"> [INFO] Batch update: 12,049 records OK</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ── MARKET SENTIMENT BANNER ── -->
                    <Border CornerRadius="12" Padding="28,22" Margin="0,0,0,8">
                        <Border.Background>
                            <SolidColorBrush Color="#1C1B1B"/>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Glow decoration -->
                            <Ellipse Width="200" Height="200" HorizontalAlignment="Right"
                                     VerticalAlignment="Top" Margin="0,-80,-80,0" Opacity="0.04">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#4CD6FB" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Market Sentiment Analysis" FontSize="20"
                                           FontWeight="Bold" Foreground="{StaticResource OnSurface}"
                                           Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource OnSurfaceVariant}"
                                           TextWrapping="Wrap" MaxWidth="500">
                                    <Run>Inferencia IA combinada (social, noticias, on-chain) indica divergencia</Run>
                                    <Run Foreground="{StaticResource PrimaryFixed}" FontWeight="Bold"> Strong Bullish</Run>
                                    <Run> en la próxima ventana de 4h.</Run>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="40,0">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="VOL INDEX" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="24.5" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurface}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="BUY/SELL" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="1.42" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurface}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="CONFIDENCE" Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="88%" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryFixed}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                    Content="Open Analytics Engine" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── STATUS BAR ── -->
                    <Border Padding="0,10,0,0" Margin="0,8,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="NODE: FRA-1" FontFamily="Consolas" FontSize="9"
                                           Foreground="#3B4A4D" Margin="0,0,20,0"/>
                                <TextBlock Text="VERSION: 1.0.0-ALPHA" FontFamily="Consolas"
                                           FontSize="9" Foreground="#3B4A4D"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Fill="{StaticResource PrimaryFixed}" Width="7" Height="7"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="SECURE LINK ESTABLISHED" FontFamily="Consolas"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- DYNAMIC CONTENT ROUTER -->
            <ContentControl x:Name="MainContentContainer" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>


